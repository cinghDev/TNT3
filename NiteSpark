    <script>
        // Tab Switching
        function switchTab(tabName) {
            // Update tab buttons
            document.querySelectorAll('.tab').forEach(tab => {
                tab.classList.remove('active');
            });
            event.target.closest('.tab').classList.add('active');
            
            // Update tab content
            document.querySelectorAll('.tab-content').forEach(content => {
                content.classList.remove('active');
            });
            document.getElementById(tabName + '-content').classList.add('active');
        }

        // Download Handler with Progress
        function downloadFile(url, filename) {
            const progressDiv = document.getElementById('downloadProgress');
            const titleEl = document.getElementById('downloadTitle');
            const infoEl = document.getElementById('downloadInfo');
            const fillEl = document.getElementById('progressFill');
            
            // Show progress indicator
            progressDiv.classList.add('show');
            titleEl.textContent = 'Downloading ' + filename;
            infoEl.textContent = 'Starting download...';
            fillEl.style.width = '0%';
            
            // Simulate progress (since we can't track actual Google Drive download progress)
            let progress = 0;
            const interval = setInterval(() => {
                progress += Math.random() * 15;
                if (progress > 90) progress = 90;
                fillEl.style.width = progress + '%';
                infoEl.textContent = Math.round(progress) + '% complete';
            }, 500);
            
            // Create hidden link and trigger download
            const link = document.createElement('a');
            link.href = url;
            link.download = filename;
            link.style.display = 'none';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            
            // Complete after 3 seconds
            setTimeout(() => {
                clearInterval(interval);
                fillEl.style.width = '100%';
                infoEl.textContent = 'Download started! Check your downloads folder.';
                titleEl.textContent = 'Download Started';
                
                // Auto-close after 3 more seconds
                setTimeout(() => {
                    progressDiv.classList.remove('show');
                }, 3000);
            }, 3000);
        }

        function closeDownloadProgress() {
            document.getElementById('downloadProgress').classList.remove('show');
        }

        // Smooth Scrolling
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });

        // Deeplink Handling
        // Check if page was loaded with deeplink parameters
        window.addEventListener('DOMContentLoaded', async () => {
            const urlParams = new URLSearchParams(window.location.search);
            const deeplinkData = urlParams.get('data');
            
            if (deeplinkData) {
                console.log('Deeplink detected on page load');
                
                // Check if this is a playlist deeplink
                const isPlaylistDeeplink = window.location.pathname.includes('/playlist');
                
                if (isPlaylistDeeplink) {
                    console.log('Playlist deeplink detected');
                    // Show overlay
                    document.getElementById('deeplink-overlay').style.display = 'flex';
                    
                    // Try to open in app
                    const customSchemeUrl = `rubyplayer://playlist?data=${deeplinkData}`;
                    window.location.href = customSchemeUrl;
                    
                    // Hide overlay after 3 seconds
                    setTimeout(() => {
                        document.getElementById('deeplink-overlay').style.display = 'none';
                        alert('If Ruby Player didn\'t open, please install it first and try again.');
                    }, 3000);
                } else {
                    console.log('Channel deeplink detected');
                    // Show overlay
                    document.getElementById('deeplink-overlay').style.display = 'flex';
                    
                    // Try to open in app
                    const customSchemeUrl = `rubyplayer://play?data=${deeplinkData}`;
                    window.location.href = customSchemeUrl;
                    
                    // Hide overlay after 3 seconds
                    setTimeout(() => {
                        document.getElementById('deeplink-overlay').style.display = 'none';
                        alert('If Ruby Player didn\'t open, please install it first and try again.');
                    }, 3000);
                }
            }
        });

        // Handle custom protocol registration for PC
        if (navigator.registerProtocolHandler) {
            try {
                navigator.registerProtocolHandler(
                    'rubyplayer',
                    window.location.origin + '/play?data=%s',
                    'Ruby Player'
                );
            } catch (e) {
                console.log('Protocol handler registration not supported:', e);
            }
        }
    </script>
