    <script>
        // Tab switching
        function switchTab(platform) {
            // Update tab buttons
            document.querySelectorAll('.tab').forEach(tab => tab.classList.remove('active'));
            event.target.classList.add('active');

            // Update tab content
            document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
            document.getElementById(platform + '-content').classList.add('active');
        }

        // Deep link handling (preserved from original)
        const urlParams = new URLSearchParams(window.location.search);
        const data = urlParams.get('data');
        const isPlaylist = window.location.pathname.startsWith('/playlist');
        const schemeHost = isPlaylist ? "playlist" : "play";
        const customSchemeUrl = "rubyplayer://" + schemeHost + "?data=" + (data ? data : "");
        const intentUrl = "intent://" + schemeHost + "?data=" + data + "#Intent;scheme=rubyplayer;package=com.niet.rubyplayer;end";

        if (data) {
            // Update overlay text
            if (isPlaylist) {
                document.querySelector('.deeplink-title').innerText = "Opening Shared Playlist...";
            }

            // Show overlay
            document.getElementById('deeplink-overlay').style.display = 'flex';
            document.body.style.overflow = 'hidden';

            // Auto-redirect attempts
            setTimeout(function () {
                window.location.href = customSchemeUrl;
            }, 500);

            setTimeout(function () {
                window.location.href = intentUrl;
            }, 1000);
        }

        function forceOpen() {
            if (data) {
                window.location.href = customSchemeUrl;
            }
        }

        // Smooth scrolling
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });
